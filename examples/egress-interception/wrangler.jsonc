{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "egress-workers",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-06",
  "compatibility_flags": ["nodejs_compat", "experimental"],
  "observability": {
    "enabled": true,
  },
  "containers": [
    {
      "class_name": "MyContainer",
      "image": "./Dockerfile",
      "max_instances": 3,
      "name": "egress-workers"
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "MyContainer",
        "name": "MY_CONTAINER",
      },
    ],
  },
  "migrations": [
    {
      "new_sqlite_classes": ["MyContainer"],
      "tag": "v1",
    },
  ],
}
